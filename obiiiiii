def main():
    import argparse
    parser = argparse.ArgumentParser()
    parser.add_argument("--json_path", help="Path to saved JSON payload")
    parser.add_argument("--excel_path", help="Path to Excel file (legacy)")
    parser.add_argument("--out_path", default="benefits_ifp2_output.xlsx")
    args = parser.parse_args()
    
    if args.json_path:
        with open(args.json_path, "r", encoding="utf-8") as f:
            data = json.load(f)
        # Use the new core function
        results = run_benefit_processing(data)
        out_df = pd.DataFrame(results)
    elif args.excel_path:
        df = pd.read_excel(args.excel_path, engine="openpyxl")
        results = run_benefit_processing(df)
        out_df = pd.DataFrame(results)
    else:
        raise ValueError("Provide --json_path or --excel_path")
        
    with pd.ExcelWriter(args.out_path, engine="openpyxl") as xw:
        out_df.to_excel(xw, index=False, sheet_name="Sheet1")
    print(f"Wrote {len(out_df)} rows to {args.out_path}")

if __name__ == "__main__":
    main()
