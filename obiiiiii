import requests
import json

# The URL where your main.py is running
URL = "http://127.0.0.1:8000/save"

# Mock data matching the structure in your screenshot
test_payload = [
    {
        "loadID": "TEST_LOAD_001",
        "filename": "H1234-001-000_Plan_Material.pdf",
        "ID": "1",
        "header": "Plan Characteristics",
        "category": "Plan Details",
        "field": "Plan Name",
        "value": "Sample Medicare Advantage Plan",
        "DT": "2026-03-16"
    },
    {
        "loadID": "TEST_LOAD_001",
        "filename": "H1234-001-000_Plan_Material.pdf",
        "ID": "2",
        "header": "Benefit Information",
        "category": "Dental Services",
        "field": "Preventive Dental",
        "value": "0% coinsurance",
        "DT": "2026-03-16"
    }
]

def run_test():
    print(f"Sending request to {URL}...")
    try:
        response = requests.post(URL, json=test_payload)
        
        if response.status_code == 201:
            print("✅ Success!")
            print("Response Data:", json.dumps(response.json(), indent=2))
        else:
            print(f"❌ Failed with status code: {response.status_code}")
            print("Error details:", response.text)
            
    except Exception as e:
        print(f"❌ Error connecting to server: {e}")

if __name__ == "__main__":
    run_test()
