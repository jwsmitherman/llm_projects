LLM_SYSTEM = """
You are a strict information extraction engine for Medicare PBP parsing.
Given rows for a single benefit context, map them to the target fields.
"""

def get_llm():
    if AzureChatOpenAI is None:
        return None
    key = os.getenv("AZURE_OPENAI_API_KEY")
    endpoint = os.getenv("AZURE_OPENAI_ENDPOINT")
    deployment = os.getenv("AZURE_OPENAI_DEPLOYMENT")
    api_version = os.getenv("AZURE_OPENAI_API_VERSION", "2024-10-21")
    
    if not all([key, endpoint, deployment]):
        return None
        
    return AzureChatOpenAI(
        azure_deployment=deployment,
        api_key=key,
        azure_endpoint=endpoint,
        api_version=api_version,
        temperature=0.0,
        max_tokens=1500,
        request_timeout=60.0
    )

def llm_map_records(llm, rows, allowed_benefit_names=None, default_coverage="InNetwork"):
    if llm is None:
        return None
        
    instructions = {
        "default_coverage": default_coverage,
        "schema": {"benefitname": "coveragetypedesc", "servicetypedesc": "benefitdesc", "benefitdesc": "tinydescription"},
        "allowed_benefit_names": allowed_benefit_names or [],
        "rows": 2500
    }
    
    messages = [
        SystemMessage(content=LLM_SYSTEM),
        HumanMessage(content=f"Map these rows to schema. JSON only.\n" + json.dumps(instructions))
    ]
    
    try:
        resp = llm(messages)
        data = json.loads(resp.content)
        if isinstance(data, list):
            return data
        return data.get("rows", [])
    except:
        return []

