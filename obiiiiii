def normalize_text(s: Optional[str]) -> str:
    if s is None or pd.isna(s):
        return ""
    return re.sub(r"\s+", " ", str(s)).strip()

def derive_planid_from_filename(filename: str) -> str:
    base = os.path.basename(filename)
    import re as _re
    m = _re.search(r"([A-Z0-9]+)-([A-Z0-9]+)-([0-9]{3})", base)
    if not m:
        contract, plan, segment = None, None, None
        m = _re.search(r"([A-Z][0-9]{4})-([0-9]{3})-([0-9]{3})", base)
        if m:
            contract, plan, segment = m.group(1), m.group(2), m.group(3)
        else:
            nums = _re.findall(r"[A-Z0-9]{3,}", base)
            if len(nums) >= 3:
                contract, plan, segment = nums[0], nums[1], nums[2]
        if not all([contract, plan, segment]):
            return f"CAM_{base}"
    else:
        contract, plan, segment = m.group(1), m.group(2), m.group(3)
    
    seq = str(int(segment))
    return f"CAM_{contract}_{plan}_{seq}"

def extract_plan_metadata(df_plan_rows: pd.DataFrame) -> Tuple[str, str, str]:
    filename = str(df_plan_rows["filename"].iloc[0])
    planid = derive_planid_from_filename(filename)
    planname = None
    plantype = None
    
    try:
        name_row = df_plan_rows[
            (df_plan_rows["header"] == "Plan Characteristics") &
            (df_plan_rows["field"].str.contains("Plan Name", na=False))
        ]
        if len(name_row) > 0:
            planname = normalize_text(name_row["value"].iloc[0])
            
        type_row = df_plan_rows[
            (df_plan_rows["header"] == "Plan Characteristics") &
            (df_plan_rows["category"].str.contains("Plan Details", na=False)) &
            (df_plan_rows["field"].str.contains("Plan Type", na=False))
        ]
        if len(type_row) > 0:
            plantype = normalize_text(type_row["value"].iloc[0])
    except:
        pass
        
    if not planname:
        import re as _re
        planname = _re.sub(r"[-_]", " ", os.path.splitext(filename)[0])
        
    if not plantype:
        if (df_plan_rows["category"].astype(str).str.contains("POS (Point of Service)", case=False)).any():
            plantype = "POS"
        else:
            plantype = "General"
            
    return planid, planname, plantype

def coverage_text_to_id_desc(text: str) -> Tuple[int, str]:
    t = normalize_text(text).lower()
    if "out of network" in t or "out-of-network" in t or t.startswith("oon"):
        return 2, "OutOfNetwork"
    if "point of service" in t or t.startswith("pos"):
        return 3, "General"
    if "in-network" in t or t.startswith("inn"):
        return 1, "InNetwork"
    return 4, "NA"

