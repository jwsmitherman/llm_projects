def detect_families(grp: pd.DataFrame) -> List[Tuple[int, str]]:
    found = []
    text_series = (grp["category"].astype(str) + " " + grp["field"].astype(str)).str.lower()
    for kw, bid in FAMILY_KEYWORDS.items():
        if any(text_series.str.contains(kw.lower(), na=False)):
            found.append((bid, CANON_FAMILIES.get(bid, "Unknown")))
    
    seen_out = set()
    out = []
    for bid, bname in found:
        if bid not in seen_out:
            out.append((bid, bname))
            seen_out.add(bid)
    
    return out or [(900, "Doctor Office Visits Select Primary")]

# =================================================================
# NEW: CORE PROCESSING FUNCTION FOR API
# =================================================================

def run_benefit_processing(data_input: Union[list, pd.DataFrame]) -> list:
    """
    Main entry point for API calls. 
    Takes a list of JSON rows, processes them, and returns a list of dictionaries.
    """
    if isinstance(data_input, list):
        df = pd.DataFrame(data_input)
    else:
        df = data_input

    # Basic normalization for consistency
    for col in ["header", "category", "field", "value"]:
        if col in df.columns:
            df[col] = df[col].astype(str).fillna("").map(normalize_text)
            
    out_rows = []
    llm = get_llm()
    
    for fname, grp in df.groupby("filename"):
        planid, planname, plantype = extract_plan_metadata(grp)
        default_cov = "POS" if plantype.upper().startswith("POS") else "InNetwork"
        
        compact = []
        for _, r in grp.iterrows():
            compact.append({
                "header": normalize_text(r.get("header")),
                "category": normalize_text(r.get("category")),
                "field": normalize_text(r.get("field")),
                "value": normalize_text(r.get("value"))
            })
            
        allowed_names = [name for name in CANON_FAMILIES.values()]
        mapped = llm_map_records(llm, compact, allowed_benefit_names=allowed_names, default_coverage=default_cov)
        
        if not mapped:
            families = detect_families(grp)
            mapped = []
            for bid, bname in families:
                mapped.append({
                    "benefitname": bname,
                    "benefitid": bid,
                    "coveragetypedesc": default_cov,
                    "servicetypedesc": "N/A",
                    "benefitdesc": f"Auto-generated summary for {bname} based on plan materials.",
                    "tinydescription": "See brochure"
                })
        
        for rec in mapped:
            bname = normalize_text(rec.get("benefitname")) or "General Benefit"
            cov_desc = normalize_text(rec.get("coveragetypedesc")) or default_cov
            st_desc = normalize_text(rec.get("servicetypedesc")) or "N/A"
            longv = rec.get("benefitdesc") or ""
            tinyv = rec.get("tinydescription") or ""
            
            bid = None
            for cand_id, cand_name in CANON_FAMILIES.items():
                if normalize_text(cand_name).lower() == bname.lower():
                    bid = cand_id
                    break
            if bid is None:
                bid = abs(hash(bname)) % (10**4)
                
            cov_id, cov_std = coverage_text_to_id_desc(cov_desc)
            
            out_rows.append({
                "planid": planid,
                "planname": planname,
                "plantypeid": plantype,
                "benefitid": bid,
                "benefitname": bname,
                "coveragetypeid": cov_id,
                "coveragetypedesc": cov_std,
                "servicetypedesc": st_desc,
                "benefitdesc": longv,
                "tinydescription": tinyv
            })
            
    return out_rows

